# Server
# Host interface uvicorn binds to.
# Keep 127.0.0.1 for local-only access; use 0.0.0.0 only behind a trusted reverse proxy/firewall.
KB_HOST=127.0.0.1
# TCP port for the FastAPI/MCP HTTP server.
KB_PORT=9999
# HTTP path where the MCP Streamable HTTP endpoint is mounted.
KB_MCP_PATH=/mcp
# Runtime log level accepted by the Python logger/uvicorn: debug, info, warning, or error.
KB_LOG_LEVEL=info

# Vault
# Root directory of the Obsidian/Markdown knowledge-base vault.
# Every note path is resolved inside this directory.
KB_VAULT_PATH=/srv/kb/vault
# SQLite state database path for server metadata/state that should live outside the vault files.
KB_STATE_DB=/srv/kb/state/personal-kb.sqlite3
# Maximum allowed note size in bytes for write operations. 102400 bytes = 100 KiB.
KB_MAX_NOTE_BYTES=102400

# Auth
# Configured HTTP auth mode. Settings currently accept bearer-token mode.
KB_AUTH_MODE=bearer
# Bearer token value for auth-enabled deployments.
# Replace with a long random secret and never commit a real token.
KB_API_KEY=change-me-generate-a-long-random-token

# Writes / Git
# Master feature gate for write-capable tools. Set false for read/status-only deployments.
KB_ENABLE_WRITES=true
# Feature gate for move/rename operations inside the vault.
KB_ENABLE_MOVE=true
# Feature gate for archive operations, usually moving notes aside instead of deleting them.
KB_ENABLE_ARCHIVE=true
# Feature gate for permanent deletion. Keep false unless destructive deletes are explicitly required.
KB_ENABLE_HARD_DELETE=false
# Require callers to send the current source hash when updating existing notes to prevent lost updates.
KB_REQUIRE_IF_HASH_FOR_UPDATES=true
# Require provenance metadata/trailers on writes so generated notes remain auditable.
KB_REQUIRE_PROVENANCE=true

# Vector DB extension point, disabled in v1
# Enable vector search/indexing integration. Keep false until a concrete provider is wired.
KB_VECTOR_ENABLED=false
# Vector database provider name. Use none while vector integration is disabled.
KB_VECTOR_PROVIDER=none
# Vector collection/index name to use when a vector provider is enabled.
KB_VECTOR_COLLECTION=personal_kb
# Vector database connection URL. Leave empty when no vector provider is configured.
KB_VECTOR_URL=
# Embedding provider name. Use none while embeddings are disabled.
KB_EMBEDDING_PROVIDER=none
# Embedding model identifier for the configured provider. Leave empty when embeddings are disabled.
KB_EMBEDDING_MODEL=
