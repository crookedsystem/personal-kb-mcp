# Server
# Host interface uvicorn binds to.
# Keep 127.0.0.1 for local-only access; use 0.0.0.0 only behind a trusted reverse proxy/firewall.
KB_HOST=127.0.0.1
# TCP port for the FastAPI/MCP HTTP server.
KB_PORT=9999
# HTTP path where the MCP Streamable HTTP endpoint is mounted.
KB_MCP_PATH=/mcp
# Runtime log level accepted by the Python logger/uvicorn: debug, info, warning, or error.
KB_LOG_LEVEL=info

# Vault
# Markdown vault opened by Obsidian and written by MCP tools.
# Point this at the vault root containing SCHEMA.md, index.md, log.md, raw/, entities/, concepts/, comparisons/, and queries/.
# Do not point this at this repository's src/ directory or at an Obsidian .obsidian/ settings directory.
KB_VAULT_PATH=/srv/llm-wiki/vault

# GitHub push
# Manual push is available through the kb_push_vault MCP tool.
# Set KB_GITHUB_PUSH_ENABLED=true to also run an automatic background push every random 30-60 minutes.
# The push commits all pending vault changes with a UTC "YYYY-MM-DD HH:MM - vault sync" commit message,
# then pushes origin/current-branch. The server checks gh auth first, then falls back to git push.
KB_GITHUB_PUSH_ENABLED=false

# Agent setup entrypoint
# scripts/main.py reads this file by default.
# Already-exported shell variables override values from .env.
# Optional explicit MCP URL. If unset, setup builds it from LLM_WIKI_MCP_SCHEME + LLM_WIKI_MCP_HOST/KB_HOST + KB_PORT + KB_MCP_PATH.
# LLM_WIKI_MCP_URL=http://127.0.0.1:9999/mcp
# Optional client-facing host override. Use this when KB_HOST binds to 0.0.0.0 but local agents should connect to 127.0.0.1 or a DNS name.
# LLM_WIKI_MCP_HOST=127.0.0.1
# LLM_WIKI_MCP_SCHEME=http
# Optional common server name override. Defaults: Hermes/Codex=llm_wiki, Claude=llm-wiki.
# LLM_WIKI_MCP_SERVER_NAME=llm_wiki
# Agent-specific install locations and options.
# HERMES_HOME=/home/alice/.hermes
# CLAUDE_SKILLS_DIR=/home/alice/.claude/skills
# CLAUDE_MCP_SCOPE=user
# CODEX_HOME=/home/alice/.codex
# CODEX_SKILLS_DIR=/home/alice/.codex/skills
# CODEX_CONFIG_PATH=/home/alice/.codex/config.toml

# Hook setup
# Setup installs input/stop hook scaffolds by default. Disable only if you want to wire hooks manually.
# LLM_WIKI_INSTALL_HOOKS=true
# HERMES_LLM_WIKI_HOOKS_DIR=/home/alice/.hermes/hooks/llm-wiki
# CLAUDE_HOOKS_DIR=/home/alice/.claude/hooks/llm-wiki
# CLAUDE_SETTINGS_PATH=/home/alice/.claude/settings.json
# CODEX_LLM_WIKI_HOOKS_DIR=/home/alice/.codex/hooks/llm-wiki
